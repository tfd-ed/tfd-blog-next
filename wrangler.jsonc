{
  "compatibility_date": "2025-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "secrets": ["YOUTUBE_API_KEY"],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}